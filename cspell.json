{
  "version": "0.2",
  "language": "en",
  "ignorePaths": [
    "node_modules/**",
    ".next/**",
    ".source/**",
    "Reference/**",
    "public/wiki-images/**",
    "content/docs/fr-FR/**",
    "content/docs/pt-BR/**",
    "content/docs/tr-TR/**",
    "bun.lock",
    "package-lock.json"
  ],
  "ignoreRegExpList": [
    "https?://[^\\s)]+",
    "[A-Za-z]+[A-Z][a-z]+[A-Za-z]*",
    "v\\d+(\\.\\d+)*",
    "#[0-9a-fA-F]{3,8}",
    "\\b[A-Fa-f0-9]{7,}\\b"
  ],
  "words": [
    "Ahri", "Akali", "Ashe", "Darius", "Ezreal", "Garen", "Jinx", "Lux", "Sona", "Yasuo", "Zed",
    "LtMAO", "RitoBin", "CSLOL", "Celestial", "Blockbench",
    "fantome", "ritoclient", "vfx", "skinline", "Riot", "Vanguard", "emitter", "rigging", "UVs",
    "Divine", "divineskins", "Fumadocs", "shadcn", "Tailwind", "Crowdin", "MDXEditor", "Octokit",
    "Lucide", "Manrope", "JetBrains",
    "nanoid", "zod", "clsx", "twMerge", "Radix", "posthog", "crowdin", "lychee",
    "mdx", "pnj", "webp", "opengraph"
  ]
}
